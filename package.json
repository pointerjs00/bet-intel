{
  "name": "betintel",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:shared": "pnpm --filter @betintel/shared build",
    "dev:api": "pnpm --filter api dev",
    "dev:mobile": "pnpm --filter mobile start",
    "build:api": "pnpm --filter @betintel/shared build && pnpm --filter api build",
    "lint": "pnpm -r lint"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
