{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "internal": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_RELEASE_API_BASE_URL": "https://betintel-api.stream-intel.online/api"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_RELEASE_API_BASE_URL": "https://betintel-api.stream-intel.online/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}