// apps/api/src/prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum AuthProvider {
  EMAIL  // username + password
  GOOGLE // Google OAuth via Firebase
  HYBRID // account has both methods linked
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum Sport {
  FOOTBALL
  BASKETBALL
  TENNIS
  HANDBALL
  VOLLEYBALL
  HOCKEY
  RUGBY
  AMERICAN_FOOTBALL
  BASEBALL
  OTHER
}

enum BoletinStatus {
  PENDING  // awaiting results
  WON
  LOST
  VOID     // cancelled/void events
  PARTIAL  // some events void
  CASHOUT  // user cashed out early
}

enum ItemResult {
  PENDING
  WON
  LOST
  VOID
}

enum RequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  BOLETIN_SHARED
  BOLETIN_RESULT
  SYSTEM
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                  String       @id @default(cuid())
  email               String       @unique
  username            String       @unique
  passwordHash        String?      // null for Google-only accounts
  googleId            String?      @unique // Firebase UID from Google Sign-In
  authProvider        AuthProvider @default(EMAIL)
  isEmailVerified     Boolean      @default(false)
  emailVerifyToken    String?      @unique
  emailVerifyExpiry   DateTime?
  passwordResetToken  String?      @unique
  passwordResetExpiry DateTime?
  displayName         String?
  avatarUrl           String?
  bio                 String?
  expoPushToken       String?
  theme               Theme        @default(SYSTEM)
  currency            String       @default("EUR")
  defaultBoletinsPublic Boolean    @default(false)
  goals               Json         @default("[]")
  lastLoginAt         DateTime?
  failedLoginAttempts Int          @default(0)
  lockedUntil         DateTime?    // brute-force lockout
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  boletins         Boletin[]
  refreshTokens    RefreshToken[]
  friendships      Friendship[]    @relation("UserFriendships")
  friendOf         Friendship[]    @relation("FriendFriendships")
  sentRequests     FriendRequest[] @relation("SentRequests")
  receivedRequests FriendRequest[] @relation("ReceivedRequests")
  sentSharedBoletins     SharedBoletin[] @relation("SharedBoletinSender")
  receivedSharedBoletins SharedBoletin[] @relation("SharedBoletinRecipient")
  notifications    Notification[]
  favourites       UserFavourite[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Reference Data ───────────────────────────────────────────────────────────

model Competition {
  id        String   @id @default(cuid())
  name      String
  country   String
  sport     Sport    @default(FOOTBALL)
  tier      Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  teams     TeamCompetition[]

  @@unique([name, country, sport])
  @@index([sport])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  sport     Sport    @default(FOOTBALL)
  country   String?
  createdAt DateTime @default(now())

  competitions TeamCompetition[]

  @@unique([name, sport])
}

model TeamCompetition {
  teamId        String
  competitionId String
  team          Team        @relation(fields: [teamId], references: [id])
  competition   Competition @relation(fields: [competitionId], references: [id])

  @@id([teamId, competitionId])
}

model Market {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String?
  sport       Sport?
  createdAt   DateTime @default(now())

  @@index([sport])
}

model Boletin {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String?
  siteSlug        String?       // betting site slug, e.g. "betclic"
  stake           Decimal       @db.Decimal(10, 2)
  totalOdds       Decimal       @db.Decimal(10, 4)
  potentialReturn Decimal       @db.Decimal(10, 2)
  status          BoletinStatus @default(PENDING)
  actualReturn    Decimal?      @db.Decimal(10, 2)
  cashoutAmount   Decimal?      @db.Decimal(10, 2) // amount received when cashing out early
  notes           String?
  isPublic        Boolean       @default(false)
  isFreebet       Boolean       @default(false) // stake was a bookmaker freebet — not real money out of pocket
  betDate         DateTime?     // actual date the bet was placed (may differ from createdAt)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items      BoletinItem[]
  sharedWith SharedBoletin[]

  @@index([userId, status])
}

model BoletinItem {
  id          String     @id @default(cuid())
  boletinId   String
  boletin     Boletin    @relation(fields: [boletinId], references: [id], onDelete: Cascade)
  homeTeam    String
  awayTeam    String
  competition String
  sport       Sport      @default(FOOTBALL)
  market      String
  selection   String
  oddValue    Decimal    @db.Decimal(10, 2)
  result      ItemResult @default(PENDING)
  kickoffAt   DateTime?  @db.Timestamptz(3)

  @@index([boletinId])
  @@index([kickoffAt])
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  user      User     @relation("UserFriendships", fields: [userId], references: [id])
  friend    User     @relation("FriendFriendships", fields: [friendId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
}

model FriendRequest {
  id         String        @id @default(cuid())
  senderId   String
  receiverId String
  sender     User          @relation("SentRequests", fields: [senderId], references: [id])
  receiver   User          @relation("ReceivedRequests", fields: [receiverId], references: [id])
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, status])
}

model SharedBoletin {
  id         String   @id @default(cuid())
  boletinId  String
  boletin    Boletin  @relation(fields: [boletinId], references: [id], onDelete: Cascade)
  sharedById String
  sharedBy   User     @relation("SharedBoletinSender", fields: [sharedById], references: [id])
  sharedWithId String
  sharedWith User     @relation("SharedBoletinRecipient", fields: [sharedWithId], references: [id], onDelete: Cascade)
  message    String?
  createdAt  DateTime @default(now())

  @@unique([boletinId, sharedWithId])
  @@index([sharedWithId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ─── Favourites ───────────────────────────────────────────────────────────────

enum FavouriteType {
  COMPETITION // a specific competition/tournament
  COUNTRY     // all competitions in a country (for a sport)
  TEAM        // a specific team/player
}

model UserFavourite {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      FavouriteType
  sport     Sport
  /// Competition name, country name, or team name depending on type
  targetKey String
  sortOrder Int @default(0)
  createdAt DateTime      @default(now())

  @@unique([userId, type, sport, targetKey])
  @@index([userId, sport])
}

// ─── Fixture data ──────────────────────────────────────────────────────────────

model Fixture {
  id               String   @id @default(cuid())
  homeTeam         String
  awayTeam         String
  homeTeamNormKey  String?
  awayTeamNormKey  String?
  competition      String
  country          String
  sport            String   @default("FOOTBALL")
  kickoffAt        DateTime @db.Timestamptz(3)
  season           String
  round            String?
  homeScore        Int?
  awayScore        Int?
  htHomeScore      Int?
  htAwayScore      Int?
  status           String   @default("SCHEDULED") // SCHEDULED | LIVE | FINISHED
  externalId       String?  @unique
  apiFootballId    Int?     @unique
  venueId          Int?
  venueName        String?
  refereeName      String?
  homeTeamApiId    Int?
  awayTeamApiId    Int?
  elapsedMinutes   Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([homeTeam, awayTeam, season, round], name: "fixture_unique")
  @@index([homeTeam, awayTeam, kickoffAt])
  @@index([competition, kickoffAt])
  @@index([kickoffAt])
  @@index([status, kickoffAt])
  @@index([homeTeamNormKey])
  @@index([awayTeamNormKey])
}

// ─── Team statistics (materialised from Fixture) ──────────────────────────────

model TeamStat {
  id               String   @id @default(cuid())
  team             String
  teamNormKey      String?
  teamName         String?
  competition      String
  season           String
  country          String

  played           Int      @default(0)
  won              Int      @default(0)
  drawn            Int      @default(0)
  lost             Int      @default(0)
  goalsFor         Int      @default(0)
  goalsAgainst     Int      @default(0)
  points           Int      @default(0)
  position         Int?

  homeWon          Int      @default(0)
  homeDrawn        Int      @default(0)
  homeLost         Int      @default(0)
  homeGoalsFor     Int      @default(0)
  homeGoalsAgainst Int      @default(0)
  awayWon          Int      @default(0)
  awayDrawn        Int      @default(0)
  awayLost         Int      @default(0)
  awayGoalsFor     Int      @default(0)
  awayGoalsAgainst Int      @default(0)

  cleanSheets      Int      @default(0)
  failedToScore    Int      @default(0)
  bttsCount        Int      @default(0)
  over25Count      Int      @default(0)
  over15Count      Int      @default(0)
  formLast5        String?

  htWon            Int      @default(0)
  htDrawn          Int      @default(0)
  htLost           Int      @default(0)
  comebacks        Int      @default(0)

  // CSV-sourced averages
  avgGoalsScored    Float?
  avgGoalsConceded  Float?
  avgShotsFor       Float?
  avgShotsAgainst   Float?
  cleanSheetPct     Float?
  bttsPct           Float?
  over15Pct         Float?
  over25Pct         Float?
  over35Pct         Float?
  failedToScorePct  Float?
  avgCornersFor     Float?
  avgCornersAgainst Float?
  avgYellowCards    Float?
  standingsSource   String?
  statsSource       String?

  updatedAt        DateTime @updatedAt

  @@unique([team, competition, season], name: "teamstat_unique")
  @@index([competition, season, points])
  @@index([teamNormKey, competition, season])
}

// ─── Match statistics (sourced from football-data.co.uk CSVs) ─────────────────

model MatchStat {
  id                  String   @id @default(cuid())

  fixtureId           String?
  homeTeam            String
  awayTeam            String
  homeTeamNormKey     String
  awayTeamNormKey     String
  competition         String
  season              String
  date                DateTime

  homeScore           Int?
  awayScore           Int?
  htHomeScore         Int?
  htAwayScore         Int?

  homeShotsTotal      Int?
  awayShotsTotal      Int?
  homeShotsOnTarget   Int?
  awayShotsOnTarget   Int?

  homeCorners         Int?
  awayCorners         Int?

  homeYellow          Int?
  awayYellow          Int?
  homeRed             Int?
  awayRed             Int?

  homeFouls           Int?
  awayFouls           Int?
  homeOffsides        Int?
  awayOffsides        Int?

  b365HomeWin         Float?
  b365Draw            Float?
  b365AwayWin         Float?
  b365Over25          Float?
  b365Under25         Float?

  pinnacleHomeWin     Float?
  pinnacleDraw        Float?
  pinnacleAwayWin     Float?
  pinnacleOver25      Float?
  pinnacleUnder25     Float?

  avgOddsHome         Float?
  avgOddsDraw         Float?
  avgOddsAway         Float?
  avgOddsOver25       Float?
  avgOddsUnder25      Float?
  maxOddsHome         Float?
  maxOddsDraw         Float?
  maxOddsAway         Float?

  source              String   @default("football-data.co.uk")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([homeTeamNormKey, awayTeamNormKey, date], name: "matchstat_unique")
  @@index([competition, season])
  @@index([homeTeamNormKey])
  @@index([awayTeamNormKey])
  @@index([date])
  @@index([fixtureId])
}

// ─── Player availability (injuries / suspensions from API-Football) ───────────

model PlayerAvailability {
  id              String    @id @default(cuid())
  leagueId        Int
  leagueName      String
  season          String
  teamId          Int?
  teamName        String
  teamNormKey     String
  playerId        Int
  playerName      String
  playerNormKey   String
  type            String
  reason          String?
  startDate       DateTime?
  endDate         DateTime?
  returnFixtureId Int?
  syncedAt        DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([playerId, leagueId, season, type], name: "availability_unique")
  @@index([teamNormKey, leagueId, season])
  @@index([leagueId, season])
}

// ─── Top scorers / assists (from API-Football) ────────────────────────────────

model TopScorer {
  id             String   @id @default(cuid())
  leagueId       Int
  leagueName     String
  season         String
  type           String   @default("goals")
  rank           Int
  playerId       Int
  playerName     String
  playerNormKey  String
  playerImageUrl String?
  nationality    String?
  age            Int?
  position       String?
  teamId         Int
  teamName       String
  teamNormKey    String
  appearances    Int?
  goals          Int
  assists        Int?
  yellowCards    Int?
  redCards       Int?
  minutesPlayed  Int?
  syncedAt       DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([leagueId, season, type, playerId], name: "topscorer_unique")
  @@index([leagueId, season, type])
  @@index([teamNormKey])
}

// ─── Data sync audit log ──────────────────────────────────────────────────────

model DataSyncLog {
  id                String    @id @default(cuid())
  jobName           String
  status            String
  recordsProcessed  Int?
  recordsUpserted   Int?
  apiCallsMade      Int?
  apiCallsRemaining Int?
  durationMs        Int?
  details           Json?
  error             String?
  startedAt         DateTime  @default(now())
  completedAt       DateTime?

  @@index([jobName, startedAt])
  @@index([status])
}

// ─── AI Scan Feedback (fine-tuning training data) ─────────────────────────────

model ScanFeedback {
  id              String   @id @default(cuid())
  userId          String
  imageBase64     String   @db.Text
  mimeType        String   @default("image/jpeg")
  aiOutput        Json     // raw result from the AI parser before user edits
  correctedOutput Json     // final user-confirmed output after editing
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
