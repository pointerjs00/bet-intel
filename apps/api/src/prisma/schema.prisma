// apps/api/src/prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum AuthProvider {
  EMAIL  // username + password
  GOOGLE // Google OAuth via Firebase
  HYBRID // account has both methods linked
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum Sport {
  FOOTBALL
  BASKETBALL
  TENNIS
  HANDBALL
  VOLLEYBALL
  HOCKEY
  RUGBY
  AMERICAN_FOOTBALL
  BASEBALL
  OTHER
}

enum BoletinStatus {
  PENDING  // awaiting results
  WON
  LOST
  VOID     // cancelled/void events
  PARTIAL  // some events void
  CASHOUT  // user cashed out early
}

enum ItemResult {
  PENDING
  WON
  LOST
  VOID
}

enum RequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  BOLETIN_SHARED
  BOLETIN_RESULT
  SYSTEM
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                  String       @id @default(cuid())
  email               String       @unique
  username            String       @unique
  passwordHash        String?      // null for Google-only accounts
  googleId            String?      @unique // Firebase UID from Google Sign-In
  authProvider        AuthProvider @default(EMAIL)
  isEmailVerified     Boolean      @default(false)
  emailVerifyToken    String?      @unique
  emailVerifyExpiry   DateTime?
  passwordResetToken  String?      @unique
  passwordResetExpiry DateTime?
  displayName         String?
  avatarUrl           String?
  bio                 String?
  expoPushToken       String?
  theme               Theme        @default(SYSTEM)
  currency            String       @default("EUR")
  defaultBoletinsPublic Boolean    @default(false)
  lastLoginAt         DateTime?
  failedLoginAttempts Int          @default(0)
  lockedUntil         DateTime?    // brute-force lockout
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  boletins         Boletin[]
  refreshTokens    RefreshToken[]
  friendships      Friendship[]    @relation("UserFriendships")
  friendOf         Friendship[]    @relation("FriendFriendships")
  sentRequests     FriendRequest[] @relation("SentRequests")
  receivedRequests FriendRequest[] @relation("ReceivedRequests")
  sentSharedBoletins     SharedBoletin[] @relation("SharedBoletinSender")
  receivedSharedBoletins SharedBoletin[] @relation("SharedBoletinRecipient")
  notifications    Notification[]
  favourites       UserFavourite[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Reference Data ───────────────────────────────────────────────────────────

model Competition {
  id        String   @id @default(cuid())
  name      String
  country   String
  sport     Sport    @default(FOOTBALL)
  tier      Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  teams     TeamCompetition[]

  @@unique([name, country, sport])
  @@index([sport])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  sport     Sport    @default(FOOTBALL)
  country   String?
  createdAt DateTime @default(now())

  competitions TeamCompetition[]

  @@unique([name, sport])
}

model TeamCompetition {
  teamId        String
  competitionId String
  team          Team        @relation(fields: [teamId], references: [id])
  competition   Competition @relation(fields: [competitionId], references: [id])

  @@id([teamId, competitionId])
}

model Market {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String?
  sport       Sport?
  createdAt   DateTime @default(now())

  @@index([sport])
}

model Boletin {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String?
  siteSlug        String?       // betting site slug, e.g. "betclic"
  stake           Decimal       @db.Decimal(10, 2)
  totalOdds       Decimal       @db.Decimal(10, 4)
  potentialReturn Decimal       @db.Decimal(10, 2)
  status          BoletinStatus @default(PENDING)
  actualReturn    Decimal?      @db.Decimal(10, 2)
  cashoutAmount   Decimal?      @db.Decimal(10, 2) // amount received when cashing out early
  notes           String?
  isPublic        Boolean       @default(false)
  isFreebet       Boolean       @default(false) // stake was a bookmaker freebet — not real money out of pocket
  betDate         DateTime?     // actual date the bet was placed (may differ from createdAt)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items      BoletinItem[]
  sharedWith SharedBoletin[]

  @@index([userId, status])
}

model BoletinItem {
  id          String     @id @default(cuid())
  boletinId   String
  boletin     Boletin    @relation(fields: [boletinId], references: [id], onDelete: Cascade)
  homeTeam    String
  awayTeam    String
  competition String
  sport       Sport      @default(FOOTBALL)
  market      String
  selection   String
  oddValue    Decimal    @db.Decimal(10, 2)
  result      ItemResult @default(PENDING)

  @@index([boletinId])
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  user      User     @relation("UserFriendships", fields: [userId], references: [id])
  friend    User     @relation("FriendFriendships", fields: [friendId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
}

model FriendRequest {
  id         String        @id @default(cuid())
  senderId   String
  receiverId String
  sender     User          @relation("SentRequests", fields: [senderId], references: [id])
  receiver   User          @relation("ReceivedRequests", fields: [receiverId], references: [id])
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, status])
}

model SharedBoletin {
  id         String   @id @default(cuid())
  boletinId  String
  boletin    Boletin  @relation(fields: [boletinId], references: [id], onDelete: Cascade)
  sharedById String
  sharedBy   User     @relation("SharedBoletinSender", fields: [sharedById], references: [id])
  sharedWithId String
  sharedWith User     @relation("SharedBoletinRecipient", fields: [sharedWithId], references: [id], onDelete: Cascade)
  message    String?
  createdAt  DateTime @default(now())

  @@unique([boletinId, sharedWithId])
  @@index([sharedWithId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ─── Favourites ───────────────────────────────────────────────────────────────

enum FavouriteType {
  COMPETITION // a specific competition/tournament
  COUNTRY     // all competitions in a country (for a sport)
  TEAM        // a specific team/player
}

model UserFavourite {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      FavouriteType
  sport     Sport
  /// Competition name, country name, or team name depending on type
  targetKey String
  createdAt DateTime      @default(now())

  @@unique([userId, type, sport, targetKey])
  @@index([userId, sport])
}
