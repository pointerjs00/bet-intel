{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node ../../node_modules/ts-node-dev/lib/bin.js --respawn --transpile-only src/index.ts",
    "build": "prisma generate --schema src/prisma/schema.prisma && tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "prisma:generate": "node ../../node_modules/prisma/build/index.js generate --schema src/prisma/schema.prisma",
    "prisma:db:push": "node ../../node_modules/prisma/build/index.js db push --schema src/prisma/schema.prisma",
    "prisma:migrate:dev": "node ../../node_modules/prisma/build/index.js migrate dev --schema src/prisma/schema.prisma",
    "prisma:migrate:deploy": "node ../../node_modules/prisma/build/index.js migrate deploy --schema src/prisma/schema.prisma",
    "prisma:studio": "node ../../node_modules/prisma/build/index.js studio --schema src/prisma/schema.prisma",
    "prisma:seed": "node ../../node_modules/ts-node/bin/ts-node src/prisma/seed.ts",
    "scrape:all": "node ../../node_modules/ts-node/bin/ts-node -e \"require('./src/jobs/scrapeJobs').initScrapeJobs().then(() => require('./src/services/scraper/scraperRegistry').runAllScrapers()).then(() => process.exit(0)).catch((e) => { console.error(e); process.exit(1); })\""
  },
  "dependencies": {
    "@betintel/shared": "workspace:*",
    "@prisma/client": "^5.14.0",
    "bcrypt": "^5.1.1",
    "bull": "^4.12.9",
    "cheerio": "^1.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "firebase-admin": "^12.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.14",
    "puppeteer-core": "^22.12.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "rate-limit-redis": "^4.2.0",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.13.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bull": "^4.10.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
